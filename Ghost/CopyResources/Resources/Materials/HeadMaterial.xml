<Material>
    <Pass name = "forward">
        <Defines>
            <GHOST_USE_NORMAL value="1" />
            <GHOST_USE_TANGENT value="1" />
        </Defines>
        <Shader source="Shaders/DefaultShader.hlsl">
            <VS entry="vs_main" />
            <PS entry="ps_main" />
        </Shader>
        <Textures>
            <texAlbedo path="Textures/head_diffuse.jpg" />
            <texNormal path="" />
        </Textures>
        <Samplers>
            <diffuseSampler>
                <MIN value="FILTER_LINEAR"/>
                <MAG value="FILTER_LINEAR"/>
                <MIP value="FILTER_LINEAR"/>
            </diffuseSampler>
        </Samplers>
    </Pass>

    <Pass name = "shadow">
        <Defines>
            <GHOST_USE_NORMAL value="1" />
            <GHOST_USE_TANGENT value="1" />
        </Defines>
        <Shader source="Shaders/DefaultShadowPass.hlsl">
            <VS entry="vs_main" />
            <PS entry="ps_main" />
        </Shader>
        <Samplers>
        </Samplers>
    </Pass>

</Material>